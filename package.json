    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-istanbul": "4.1.9",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "chart.js": "4.5.1",
    "csv": "6.6.0",
    "electron": "41.7.2",
    "electron-builder": "26.15.3",
    "electron-devtools-installer": "4.0.0",
    "electron-vite": "5.0.0",
