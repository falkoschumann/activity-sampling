    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sass": "1.101.0",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
