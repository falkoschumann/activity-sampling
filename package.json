{
  "name": "activity-sampling",
  "version": "1.0.2",
  "description": "Periodically asks the user about their current activity and logs it for analysis.",
  "keywords": [
    "pomodoro",
    "time-tracking",
    "estimation"
  ],
  "author": "Falko Schumann",
  "homepage": "https://github.com/falkoschumann/activity-sampling",
